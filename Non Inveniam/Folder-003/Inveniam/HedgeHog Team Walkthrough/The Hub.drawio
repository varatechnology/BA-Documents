        <mxCell id="FGjaAwUbEIzN111CO-pI-7" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="FGjaAwUbEIzN111CO-pI-2" target="FGjaAwUbEIzN111CO-pI-3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="FGjaAwUbEIzN111CO-pI-2" value="Hub Service" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="360" y="30" width="120" height="40" as="geometry" />
        </mxCell>
        <mxCell id="FGjaAwUbEIzN111CO-pI-11" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="FGjaAwUbEIzN111CO-pI-3" target="FGjaAwUbEIzN111CO-pI-10">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="FGjaAwUbEIzN111CO-pI-3" value="Hub" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="560" y="30" width="120" height="40" as="geometry" />
        </mxCell>
        <mxCell id="FGjaAwUbEIzN111CO-pI-5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="FGjaAwUbEIzN111CO-pI-4" target="FGjaAwUbEIzN111CO-pI-1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="FGjaAwUbEIzN111CO-pI-15" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="FGjaAwUbEIzN111CO-pI-4" target="FGjaAwUbEIzN111CO-pI-14">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="FGjaAwUbEIzN111CO-pI-4" value="UI" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="10" y="30" width="120" height="40" as="geometry" />
        </mxCell>
        <mxCell id="FGjaAwUbEIzN111CO-pI-9" value="&lt;div&gt;&lt;font style=&quot;font-size: 24px;&quot;&gt;&lt;b&gt;Integration Settings&amp;nbsp;&lt;/b&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;1. For each ledger, Deals MS create a integration settings&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;a. it checks if the Hub Connection is okay or not, then create the integrations settings&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;2. Token Symbol registration and Deployment details has been upadted integration settings&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;a. UI sends request to deals MS&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;b. deals MS send request to Hub service to send the transaction&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;c. Hub sends the transaction id to Hub Service&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;d. Hub service publishes TransactionRequestSuccessEvent with the transaction id&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;e. Deals MS update integration settings with the transaction id&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;c. Hub sends success notification to Hub-Service using Webhooks&lt;br&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;d. Transaction Success Event published by Hub Service&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;e. Deals MS update integration settings about the transaction id (success or failure)&lt;br&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="10" y="130" width="490" height="230" as="geometry" />
        </mxCell>
        <mxCell id="FGjaAwUbEIzN111CO-pI-10" value="Blockchain" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="740" y="30" width="120" height="40" as="geometry" />
        </mxCell>
        <mxCell id="FGjaAwUbEIzN111CO-pI-12" value="&lt;b&gt;&lt;font style=&quot;font-size: 20px;&quot;&gt;Document Sync Process&lt;/font&gt;&lt;/b&gt;&lt;br&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;a. UI sends document sync request to DataRoom MS&lt;br&gt;&lt;/div&gt;&lt;div&gt;c. DataRoom creates the Taxonomy for requested ledger&lt;/div&gt;&lt;div&gt;b. DataRoom MS publishes SyncDocumentRequestedEvent with newly created Taxonomy&lt;br&gt;c. Hub-Service sends transaction request to Hub and gets the transaction id&lt;/div&gt;&lt;div&gt;d. Hub sends success notification to Hub-Service using Webhooks&lt;br&gt;e. Hub-Service publishes HubSyncDocumentSucceededEvent&lt;br&gt;&lt;/div&gt;&lt;div&gt;f. DataRoom MS update the Taxonomy Object with Transaction Details.&lt;br&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="530" y="140" width="490" height="170" as="geometry" />
        </mxCell>
        <mxCell id="FGjaAwUbEIzN111CO-pI-16" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0.5;entryY=1;entryDx=0;entryDy=0;" edge="1" parent="1" source="FGjaAwUbEIzN111CO-pI-14" target="FGjaAwUbEIzN111CO-pI-2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="FGjaAwUbEIzN111CO-pI-14" value="DataRoom MS" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="200" y="70" width="120" height="40" as="geometry" />
        </mxCell>
        <mxCell id="FGjaAwUbEIzN111CO-pI-18" value="Integration Settings&lt;div&gt;for requested ledger&lt;/div&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0.75;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="FGjaAwUbEIzN111CO-pI-17" target="FGjaAwUbEIzN111CO-pI-2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
