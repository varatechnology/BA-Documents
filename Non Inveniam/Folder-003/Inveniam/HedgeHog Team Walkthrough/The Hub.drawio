  <diagram id="7HGaMuHZ_iGTYgr6sbCL" name="Inveniam Token">
    <mxGraphModel grid="1" page="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="lmHp_3FGvSW1J0t4DkZA-5" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Important Cotracts&lt;/h1&gt;&lt;p&gt;&lt;em style=&quot;color: rgb(23, 43, 77); font-family: ui-sans-serif, -apple-system, BlinkMacSystemFont, &amp;quot;Segoe UI&amp;quot;, Ubuntu, system-ui, &amp;quot;Helvetica Neue&amp;quot;, sans-serif; font-size: 16px; letter-spacing: -0.08px; white-space-collapse: preserve; background-color: rgb(255, 255, 255);&quot; data-renderer-mark=&quot;true&quot;&gt;&lt;b&gt;Main contracts&lt;/b&gt;&lt;/em&gt;&lt;span style=&quot;color: rgb(23, 43, 77); font-family: ui-sans-serif, -apple-system, BlinkMacSystemFont, &amp;quot;Segoe UI&amp;quot;, Ubuntu, system-ui, &amp;quot;Helvetica Neue&amp;quot;, sans-serif; font-size: 16px; letter-spacing: -0.08px; white-space-collapse: preserve; background-color: rgb(255, 255, 255);&quot;&gt;&lt;b&gt; that bring visible business value are&lt;/b&gt; : TokenRegistry, InveniamToken, DocumentManager and RelationManager. Main functionality is &lt;/span&gt;&lt;em style=&quot;color: rgb(23, 43, 77); font-family: ui-sans-serif, -apple-system, BlinkMacSystemFont, &amp;quot;Segoe UI&amp;quot;, Ubuntu, system-ui, &amp;quot;Helvetica Neue&amp;quot;, sans-serif; font-size: 16px; letter-spacing: -0.08px; white-space-collapse: preserve; background-color: rgb(255, 255, 255);&quot; data-renderer-mark=&quot;true&quot;&gt;registerToken, deployToken, setDocument, setRelation &lt;/em&gt;&lt;span style=&quot;color: rgb(23, 43, 77); font-family: ui-sans-serif, -apple-system, BlinkMacSystemFont, &amp;quot;Segoe UI&amp;quot;, Ubuntu, system-ui, &amp;quot;Helvetica Neue&amp;quot;, sans-serif; font-size: 16px; letter-spacing: -0.08px; white-space-collapse: preserve; background-color: rgb(255, 255, 255);&quot;&gt;(deal creation and document sync)&lt;/span&gt;&lt;br style=&quot;color: rgb(23, 43, 77); font-family: ui-sans-serif, -apple-system, BlinkMacSystemFont, &amp;quot;Segoe UI&amp;quot;, Ubuntu, system-ui, &amp;quot;Helvetica Neue&amp;quot;, sans-serif; font-size: 16px; letter-spacing: -0.08px; white-space-collapse: preserve; background-color: rgb(255, 255, 255);&quot;&gt;&lt;br style=&quot;color: rgb(23, 43, 77); font-family: ui-sans-serif, -apple-system, BlinkMacSystemFont, &amp;quot;Segoe UI&amp;quot;, Ubuntu, system-ui, &amp;quot;Helvetica Neue&amp;quot;, sans-serif; font-size: 16px; letter-spacing: -0.08px; white-space-collapse: preserve; background-color: rgb(255, 255, 255);&quot;&gt;&lt;em style=&quot;color: rgb(23, 43, 77); font-family: ui-sans-serif, -apple-system, BlinkMacSystemFont, &amp;quot;Segoe UI&amp;quot;, Ubuntu, system-ui, &amp;quot;Helvetica Neue&amp;quot;, sans-serif; font-size: 16px; letter-spacing: -0.08px; white-space-collapse: preserve; background-color: rgb(255, 255, 255);&quot; data-renderer-mark=&quot;true&quot;&gt;&lt;b&gt;Contracts that present standards &lt;/b&gt;&lt;/em&gt;&lt;span style=&quot;color: rgb(23, 43, 77); font-family: ui-sans-serif, -apple-system, BlinkMacSystemFont, &amp;quot;Segoe UI&amp;quot;, Ubuntu, system-ui, &amp;quot;Helvetica Neue&amp;quot;, sans-serif; font-size: 16px; letter-spacing: -0.08px; white-space-collapse: preserve; background-color: rgb(255, 255, 255);&quot;&gt;&lt;b&gt;implementation or libraries&lt;/b&gt;: ERC20, ERC20 Detailed, AddressList, Strings, StringUtils. (basic transfer functions, utils for work with basic types inside smart contracts) &lt;/span&gt;&lt;br style=&quot;color: rgb(23, 43, 77); font-family: ui-sans-serif, -apple-system, BlinkMacSystemFont, &amp;quot;Segoe UI&amp;quot;, Ubuntu, system-ui, &amp;quot;Helvetica Neue&amp;quot;, sans-serif; font-size: 16px; letter-spacing: -0.08px; white-space-collapse: preserve; background-color: rgb(255, 255, 255);&quot;&gt;&lt;br style=&quot;color: rgb(23, 43, 77); font-family: ui-sans-serif, -apple-system, BlinkMacSystemFont, &amp;quot;Segoe UI&amp;quot;, Ubuntu, system-ui, &amp;quot;Helvetica Neue&amp;quot;, sans-serif; font-size: 16px; letter-spacing: -0.08px; white-space-collapse: preserve; background-color: rgb(255, 255, 255);&quot;&gt;&lt;em style=&quot;color: rgb(23, 43, 77); font-family: ui-sans-serif, -apple-system, BlinkMacSystemFont, &amp;quot;Segoe UI&amp;quot;, Ubuntu, system-ui, &amp;quot;Helvetica Neue&amp;quot;, sans-serif; font-size: 16px; letter-spacing: -0.08px; white-space-collapse: preserve; background-color: rgb(255, 255, 255);&quot; data-renderer-mark=&quot;true&quot;&gt;&lt;b&gt;Contracts that are technical helpers &lt;/b&gt;&lt;/em&gt;&lt;span style=&quot;color: rgb(23, 43, 77); font-family: ui-sans-serif, -apple-system, BlinkMacSystemFont, &amp;quot;Segoe UI&amp;quot;, Ubuntu, system-ui, &amp;quot;Helvetica Neue&amp;quot;, sans-serif; font-size: 16px; letter-spacing: -0.08px; white-space-collapse: preserve; background-color: rgb(255, 255, 255);&quot;&gt;&lt;b&gt;for operational work&lt;/b&gt;: TokenRegistryProxy, FunctionProxy, Proxy, DocumentManagerFactory, TokenFactory, TokenRegistryStorage, AllowableStorage, TokenConfigurator&lt;/span&gt;&lt;br style=&quot;color: rgb(23, 43, 77); font-family: ui-sans-serif, -apple-system, BlinkMacSystemFont, &amp;quot;Segoe UI&amp;quot;, Ubuntu, system-ui, &amp;quot;Helvetica Neue&amp;quot;, sans-serif; font-size: 16px; letter-spacing: -0.08px; white-space-collapse: preserve; background-color: rgb(255, 255, 255);&quot;&gt;&lt;span style=&quot;color: rgb(23, 43, 77); font-family: ui-sans-serif, -apple-system, BlinkMacSystemFont, &amp;quot;Segoe UI&amp;quot;, Ubuntu, system-ui, &amp;quot;Helvetica Neue&amp;quot;, sans-serif; font-size: 16px; letter-spacing: -0.08px; white-space-collapse: preserve; background-color: rgb(255, 255, 255);&quot;&gt;( Contract Update, Single Entry to system, factories for creation, Shared storages, etc) &lt;/span&gt;&lt;br style=&quot;color: rgb(23, 43, 77); font-family: ui-sans-serif, -apple-system, BlinkMacSystemFont, &amp;quot;Segoe UI&amp;quot;, Ubuntu, system-ui, &amp;quot;Helvetica Neue&amp;quot;, sans-serif; font-size: 16px; letter-spacing: -0.08px; white-space-collapse: preserve; background-color: rgb(255, 255, 255);&quot;&gt;&lt;br style=&quot;color: rgb(23, 43, 77); font-family: ui-sans-serif, -apple-system, BlinkMacSystemFont, &amp;quot;Segoe UI&amp;quot;, Ubuntu, system-ui, &amp;quot;Helvetica Neue&amp;quot;, sans-serif; font-size: 16px; letter-spacing: -0.08px; white-space-collapse: preserve; background-color: rgb(255, 255, 255);&quot;&gt;&lt;em style=&quot;color: rgb(23, 43, 77); font-family: ui-sans-serif, -apple-system, BlinkMacSystemFont, &amp;quot;Segoe UI&amp;quot;, Ubuntu, system-ui, &amp;quot;Helvetica Neue&amp;quot;, sans-serif; font-size: 16px; letter-spacing: -0.08px; white-space-collapse: preserve; background-color: rgb(255, 255, 255);&quot; data-renderer-mark=&quot;true&quot;&gt;&lt;b&gt;Contracts and libraries that bring additional logic&lt;/b&gt; &lt;/em&gt;&lt;span style=&quot;color: rgb(23, 43, 77); font-family: ui-sans-serif, -apple-system, BlinkMacSystemFont, &amp;quot;Segoe UI&amp;quot;, Ubuntu, system-ui, &amp;quot;Helvetica Neue&amp;quot;, sans-serif; font-size: 16px; letter-spacing: -0.08px; white-space-collapse: preserve; background-color: rgb(255, 255, 255);&quot;&gt;- Allowable, PermissionManager, WhiteListTransferManager, Allowable Library, InveniamTokenLib, TokenRegistryLib. (functionality that  enables Role Based Access Control, helpers for token contract and additional methods for storage e.g. &lt;/span&gt;&lt;em style=&quot;color: rgb(23, 43, 77); font-family: ui-sans-serif, -apple-system, BlinkMacSystemFont, &amp;quot;Segoe UI&amp;quot;, Ubuntu, system-ui, &amp;quot;Helvetica Neue&amp;quot;, sans-serif; font-size: 16px; letter-spacing: -0.08px; white-space-collapse: preserve; background-color: rgb(255, 255, 255);&quot; data-renderer-mark=&quot;true&quot;&gt;getTokenDetailsBySymbols&lt;/em&gt;&lt;span style=&quot;color: rgb(23, 43, 77); font-family: ui-sans-serif, -apple-system, BlinkMacSystemFont, &amp;quot;Segoe UI&amp;quot;, Ubuntu, system-ui, &amp;quot;Helvetica Neue&amp;quot;, sans-serif; font-size: 16px; letter-spacing: -0.08px; white-space-collapse: preserve; background-color: rgb(255, 255, 255);&quot;&gt;)&lt;/span&gt;&lt;br&gt;&lt;/p&gt;" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="980" y="20" width="410" height="550" as="geometry" />
        </mxCell>
