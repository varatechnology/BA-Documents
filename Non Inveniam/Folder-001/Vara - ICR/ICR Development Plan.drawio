<mxfile host="app.diagrams.net" modified="2024-04-30T08:54:53.845Z" agent="Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36" etag="5KJEiV8L1ZrL8KZh3JQX" version="24.3.1" type="google" pages="4">
  <diagram name="Overview" id="bpzpi2dCxO38Uk53Bn8x">
    <mxGraphModel grid="1" page="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="aXelOI9KZ1DnYwAJU6I7-4" value="&lt;p style=&quot;margin: 1rem 0px; white-space-collapse: preserve; word-break: break-word; color: rgb(31, 31, 31); font-family: &amp;quot;Google Sans&amp;quot;, &amp;quot;Helvetica Neue&amp;quot;, sans-serif;&quot; data-sourcepos=&quot;5:1-5:29&quot;&gt;&lt;span style=&quot;font-weight: 700;&quot;&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;1. Data Management Module&lt;/font&gt;&lt;/span&gt;&lt;/p&gt;&lt;ul style=&quot;margin: 4px 0px; padding-inline-start: 1.125rem; color: rgb(31, 31, 31); font-family: &amp;quot;Google Sans&amp;quot;, &amp;quot;Helvetica Neue&amp;quot;, sans-serif;&quot; data-sourcepos=&quot;7:1-12:0&quot;&gt;&lt;li style=&quot;margin-bottom: 0px;&quot; data-sourcepos=&quot;7:1-7:132&quot;&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;&lt;span style=&quot;font-weight: 700;&quot;&gt;Data Source Configuration:&lt;/span&gt;&amp;nbsp;Define connections to various accounting systems (ERP, GL) used by subsidiaries and parent company.&lt;/font&gt;&lt;/li&gt;&lt;li style=&quot;margin-bottom: 0px;&quot; data-sourcepos=&quot;8:1-8:115&quot;&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;&lt;span style=&quot;font-weight: 700;&quot;&gt;Data Mapping:&lt;/span&gt;&amp;nbsp;Map data fields from different accounting systems to a standardized format for reconciliation.&lt;/font&gt;&lt;/li&gt;&lt;li style=&quot;margin-bottom: 0px;&quot; data-sourcepos=&quot;9:1-9:99&quot;&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;&lt;span style=&quot;font-weight: 700;&quot;&gt;Data Import/Export:&lt;/span&gt;&amp;nbsp;Securely import and export transaction data for reconciliation processes.&lt;/font&gt;&lt;/li&gt;&lt;li style=&quot;margin-bottom: 0px;&quot; data-sourcepos=&quot;10:1-10:90&quot;&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;&lt;span style=&quot;font-weight: 700;&quot;&gt;Data Transformation:&lt;/span&gt;&amp;nbsp;Cleanse, transform, and standardize data for accurate matching.&lt;/font&gt;&lt;/li&gt;&lt;li style=&quot;margin-bottom: 0px;&quot; data-sourcepos=&quot;11:1-12:0&quot;&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;&lt;span style=&quot;font-weight: 700;&quot;&gt;Data Scheduling:&lt;/span&gt;&amp;nbsp;Automate data import/export based on pre-defined schedules (daily, weekly, etc.).&lt;/font&gt;&lt;/li&gt;&lt;/ul&gt;" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="40" y="80" width="320" height="230" as="geometry" />
        </mxCell>
        <mxCell id="aXelOI9KZ1DnYwAJU6I7-5" value="&lt;p style=&quot;margin: 1rem 0px; white-space-collapse: preserve; word-break: break-word; color: rgb(31, 31, 31); font-family: &amp;quot;Google Sans&amp;quot;, &amp;quot;Helvetica Neue&amp;quot;, sans-serif;&quot; data-sourcepos=&quot;13:1-13:34&quot;&gt;&lt;span style=&quot;font-weight: 700;&quot;&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;2. Transaction Matching Module&lt;/font&gt;&lt;/span&gt;&lt;/p&gt;&lt;ul style=&quot;margin: 4px 0px; padding-inline-start: 1.125rem; color: rgb(31, 31, 31); font-family: &amp;quot;Google Sans&amp;quot;, &amp;quot;Helvetica Neue&amp;quot;, sans-serif;&quot; data-sourcepos=&quot;15:1-19:0&quot;&gt;&lt;li style=&quot;margin-bottom: 0px;&quot; data-sourcepos=&quot;15:1-15:139&quot;&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;&lt;span style=&quot;font-weight: 700;&quot;&gt;Automated Matching:&lt;/span&gt;&amp;nbsp;Identify matching transactions between subsidiaries based on pre-defined rules (invoice numbers, dates, amounts).&lt;/font&gt;&lt;/li&gt;&lt;li style=&quot;margin-bottom: 0px;&quot; data-sourcepos=&quot;16:1-16:107&quot;&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;&lt;span style=&quot;font-weight: 700;&quot;&gt;Fuzzy Matching:&lt;/span&gt;&amp;nbsp;Handle discrepancies by suggesting potential matches based on similarity algorithms.&lt;/font&gt;&lt;/li&gt;&lt;li style=&quot;margin-bottom: 0px;&quot; data-sourcepos=&quot;17:1-17:95&quot;&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;&lt;span style=&quot;font-weight: 700;&quot;&gt;Manual Matching:&lt;/span&gt;&amp;nbsp;Provide tools for manual review and matching of unmatched transactions.&lt;/font&gt;&lt;/li&gt;&lt;li style=&quot;margin-bottom: 0px;&quot; data-sourcepos=&quot;18:1-19:0&quot;&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;&lt;span style=&quot;font-weight: 700;&quot;&gt;Exception Handling:&lt;/span&gt;&amp;nbsp;Flag and categorize unmatched transactions for further investigation and resolution.&lt;/font&gt;&lt;/li&gt;&lt;/ul&gt;" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="400" y="80" width="320" height="200" as="geometry" />
        </mxCell>
        <mxCell id="aXelOI9KZ1DnYwAJU6I7-6" value="&lt;p style=&quot;margin: 1rem 0px; white-space-collapse: preserve; word-break: break-word; color: rgb(31, 31, 31); font-family: &amp;quot;Google Sans&amp;quot;, &amp;quot;Helvetica Neue&amp;quot;, sans-serif;&quot; data-sourcepos=&quot;20:1-20:37&quot;&gt;&lt;span style=&quot;font-weight: 700;&quot;&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;3. Reconciliation Workflow Module&lt;/font&gt;&lt;/span&gt;&lt;/p&gt;&lt;ul style=&quot;margin: 4px 0px; padding-inline-start: 1.125rem; color: rgb(31, 31, 31); font-family: &amp;quot;Google Sans&amp;quot;, &amp;quot;Helvetica Neue&amp;quot;, sans-serif;&quot; data-sourcepos=&quot;22:1-27:0&quot;&gt;&lt;li style=&quot;margin-bottom: 0px;&quot; data-sourcepos=&quot;22:1-22:127&quot;&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;&lt;span style=&quot;font-weight: 700;&quot;&gt;Reconciliation Dashboard:&lt;/span&gt;&amp;nbsp;Visualize the overall reconciliation status with key metrics (open items, aged discrepancies).&lt;/font&gt;&lt;/li&gt;&lt;li style=&quot;margin-bottom: 0px;&quot; data-sourcepos=&quot;23:1-23:97&quot;&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;&lt;span style=&quot;font-weight: 700;&quot;&gt;Task Management:&lt;/span&gt;&amp;nbsp;Assign tasks for resolving unmatched transactions to specific users/teams.&lt;/font&gt;&lt;/li&gt;&lt;li style=&quot;margin-bottom: 0px;&quot; data-sourcepos=&quot;24:1-24:118&quot;&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;&lt;span style=&quot;font-weight: 700;&quot;&gt;Collaboration Tools:&lt;/span&gt;&amp;nbsp;Facilitate communication and document sharing for dispute resolution between subsidiaries.&lt;/font&gt;&lt;/li&gt;&lt;li style=&quot;margin-bottom: 0px;&quot; data-sourcepos=&quot;25:1-25:77&quot;&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;&lt;span style=&quot;font-weight: 700;&quot;&gt;Approval Workflow:&lt;/span&gt;&amp;nbsp;Manage approval process for reconciled transactions.&lt;/font&gt;&lt;/li&gt;&lt;li style=&quot;margin-bottom: 0px;&quot; data-sourcepos=&quot;26:1-27:0&quot;&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;&lt;span style=&quot;font-weight: 700;&quot;&gt;Audit Trail:&lt;/span&gt;&amp;nbsp;Maintain a complete record of all reconciliation activities and user actions.&lt;/font&gt;&lt;/li&gt;&lt;/ul&gt;" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="750" y="90" width="320" height="240" as="geometry" />
        </mxCell>
        <mxCell id="aXelOI9KZ1DnYwAJU6I7-7" value="&lt;p style=&quot;margin: 1rem 0px; white-space-collapse: preserve; word-break: break-word; color: rgb(31, 31, 31); font-family: &amp;quot;Google Sans&amp;quot;, &amp;quot;Helvetica Neue&amp;quot;, sans-serif;&quot; data-sourcepos=&quot;28:1-28:39&quot;&gt;&lt;span style=&quot;font-weight: 700;&quot;&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;4. Reporting &amp;amp; Analytics Module&lt;/font&gt;&lt;/span&gt;&lt;/p&gt;&lt;ul style=&quot;margin: 4px 0px; padding-inline-start: 1.125rem; color: rgb(31, 31, 31); font-family: &amp;quot;Google Sans&amp;quot;, &amp;quot;Helvetica Neue&amp;quot;, sans-serif;&quot; data-sourcepos=&quot;30:1-35:0&quot;&gt;&lt;li style=&quot;margin-bottom: 0px;&quot; data-sourcepos=&quot;30:1-30:177&quot;&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;&lt;span style=&quot;font-weight: 700;&quot;&gt;Reconciliation Reports:&lt;/span&gt;&amp;nbsp;Generate detailed reports on reconciliation activities, including matched/unmatched transactions, identified discrepancies, and resolution history.&lt;/font&gt;&lt;/li&gt;&lt;li style=&quot;margin-bottom: 0px;&quot; data-sourcepos=&quot;31:1-31:115&quot;&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;&lt;span style=&quot;font-weight: 700;&quot;&gt;Trend Analysis:&lt;/span&gt;&amp;nbsp;Analyze trends in reconciliation data to identify recurring issues and areas for improvement.&lt;/font&gt;&lt;/li&gt;&lt;li style=&quot;margin-bottom: 0px;&quot; data-sourcepos=&quot;32:1-32:89&quot;&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;&lt;span style=&quot;font-weight: 700;&quot;&gt;Ad-hoc Reporting:&lt;/span&gt;&amp;nbsp;Allow users to create custom reports based on specific criteria.&lt;/font&gt;&lt;/li&gt;&lt;li style=&quot;margin-bottom: 0px;&quot; data-sourcepos=&quot;33:1-33:98&quot;&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;&lt;span style=&quot;font-weight: 700;&quot;&gt;Drill-Down Capabilities:&lt;/span&gt;&amp;nbsp;Enable users to investigate details behind summarized data points.&lt;/font&gt;&lt;/li&gt;&lt;li style=&quot;margin-bottom: 0px;&quot; data-sourcepos=&quot;34:1-35:0&quot;&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;&lt;span style=&quot;font-weight: 700;&quot;&gt;Reconciliation Benchmarking:&lt;/span&gt;&amp;nbsp;Compare reconciliation performance against industry benchmarks or internal historical data.&lt;/font&gt;&lt;/li&gt;&lt;/ul&gt;" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="1120" y="80" width="320" height="240" as="geometry" />
        </mxCell>
        <mxCell id="aXelOI9KZ1DnYwAJU6I7-8" value="&lt;p style=&quot;margin: 1rem 0px; white-space-collapse: preserve; word-break: break-word; color: rgb(31, 31, 31); font-family: &amp;quot;Google Sans&amp;quot;, &amp;quot;Helvetica Neue&amp;quot;, sans-serif;&quot; data-sourcepos=&quot;36:1-36:43&quot;&gt;&lt;span style=&quot;font-weight: 700;&quot;&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;5. Security &amp;amp; Administration Module&lt;/font&gt;&lt;/span&gt;&lt;/p&gt;&lt;ul style=&quot;margin: 4px 0px; padding-inline-start: 1.125rem; color: rgb(31, 31, 31); font-family: &amp;quot;Google Sans&amp;quot;, &amp;quot;Helvetica Neue&amp;quot;, sans-serif;&quot; data-sourcepos=&quot;38:1-43:0&quot;&gt;&lt;li style=&quot;margin-bottom: 0px;&quot; data-sourcepos=&quot;38:1-38:97&quot;&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;&lt;span style=&quot;font-weight: 700;&quot;&gt;User Management:&lt;/span&gt;&amp;nbsp;Create, manage, and assign user roles with appropriate access permissions.&lt;/font&gt;&lt;/li&gt;&lt;li style=&quot;margin-bottom: 0px;&quot; data-sourcepos=&quot;39:1-39:93&quot;&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;&lt;span style=&quot;font-weight: 700;&quot;&gt;Data Security:&lt;/span&gt;&amp;nbsp;Implement robust security measures to protect sensitive financial data.&lt;/font&gt;&lt;/li&gt;&lt;li style=&quot;margin-bottom: 0px;&quot; data-sourcepos=&quot;40:1-40:100&quot;&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;&lt;span style=&quot;font-weight: 700;&quot;&gt;Access Controls:&lt;/span&gt;&amp;nbsp;Restrict access to specific modules and functionalities based on user roles.&lt;/font&gt;&lt;/li&gt;&lt;li style=&quot;margin-bottom: 0px;&quot; data-sourcepos=&quot;41:1-41:80&quot;&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;&lt;span style=&quot;font-weight: 700;&quot;&gt;Audit Logging:&lt;/span&gt;&amp;nbsp;Track user activity and data access for auditing purposes.&lt;/font&gt;&lt;/li&gt;&lt;li style=&quot;margin-bottom: 0px;&quot; data-sourcepos=&quot;42:1-43:0&quot;&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;&lt;span style=&quot;font-weight: 700;&quot;&gt;System Configuration:&lt;/span&gt;&amp;nbsp;Manage system settings, preferences, and integrations with external systems.&lt;/font&gt;&lt;/li&gt;&lt;/ul&gt;" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="1520" y="80" width="320" height="240" as="geometry" />
        </mxCell>
        <mxCell id="6bG1Mg8azWMQUbI3glZd-1" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Minimum View - Product User&lt;/h1&gt;&lt;div&gt;1. User List&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;Search capability by name, email, phone number&lt;/li&gt;&lt;li&gt;Invite user button&lt;/li&gt;&lt;li&gt;Invite user form in a pop up&lt;/li&gt;&lt;li&gt;User list with following columns (name, email, phone, subsidiary, status, actions)&lt;/li&gt;&lt;li&gt;Upon clicking the user name, it will open the user details page&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;div&gt;2. User Details&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;Selected user profile details&lt;/li&gt;&lt;li&gt;Subsidiary List (right now, one user can be added to a single subsidiary, but multi-org system can be done easility by implementing 2 step token assigning process)&lt;/li&gt;&lt;li&gt;Usage and contribution related metrics can be shown here in future&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;p&gt;&lt;/p&gt;" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="40" y="370" width="395" height="300" as="geometry" />
        </mxCell>
        <mxCell id="6bG1Mg8azWMQUbI3glZd-2" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Minimum View - Subsidiary&lt;/h1&gt;&lt;div&gt;1. Subsidiary List&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;Search capability by name, location, currency, status&lt;/li&gt;&lt;li&gt;Add new subsidiary button&lt;/li&gt;&lt;li&gt;Subsidiary list with following columns (name, location, currency, status, actions)&lt;/li&gt;&lt;li&gt;Upon clicking the subsidiary name, it will open the subsidiary details page&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;div&gt;2. Subsidiary Details&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;Selected Subsidiary profile details&lt;/li&gt;&lt;li&gt;User List (name, email, phone, subsidiary, role, status)&lt;/li&gt;&lt;li&gt;Add new user to the subsidiary&lt;/li&gt;&lt;li&gt;Change role of an user&lt;/li&gt;&lt;li&gt;Usage metrics can be shown there&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;p&gt;&lt;/p&gt;" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="40" y="710" width="395" height="290" as="geometry" />
        </mxCell>
        <mxCell id="6bG1Mg8azWMQUbI3glZd-3" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Minimum View - Landing Page and Transaction List&lt;/h1&gt;&lt;div&gt;1. Landing Page (Home page of a already logged in user)&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;Logged in user in the navbar&lt;/li&gt;&lt;li&gt;List of following information&lt;/li&gt;&lt;ul&gt;&lt;li&gt;Particular type (Total count of transactions, matched transactions, on-going transactions, open transactions, amount payable, amount receibale, amount in transit, etc)&lt;/li&gt;&lt;/ul&gt;&lt;li&gt;Ledger Account Summary (only Intercompnay Accounts)&lt;/li&gt;&lt;li&gt;Upon clicking the Ledger Account, it will go to the transaction list&amp;nbsp; page of the selected ledger&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;div&gt;2. Ledger Account Transaction List Page&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;On top, minimum details of selected ledger account&lt;/li&gt;&lt;li&gt;Summary of the reconciliation state&lt;/li&gt;&lt;li&gt;A big table containing all the transaction related fields&lt;/li&gt;&lt;li&gt;Each column should have saperate seach input box&lt;/li&gt;&lt;li&gt;At the end of the table summary will be shown&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;p&gt;&lt;/p&gt;" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="530" y="360" width="395" height="350" as="geometry" />
        </mxCell>
        <mxCell id="ftyFr8wdyjRYy_RAENV8-1" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Minimum View - Reconciliation Page&lt;/h1&gt;&lt;div&gt;1. Reconciliation Page&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;Show List of Entity Pairs and its reconciliation state&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;div&gt;2. Reconciliation Details&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;Detailed Summary of the reconciliation&lt;/li&gt;&lt;li&gt;Ledger Account Summary involved into the reconciliation&lt;/li&gt;&lt;li&gt;Upon clicking the ledger account, it will go to the Ledger Account Transaction List page&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;p&gt;&lt;/p&gt;" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="540" y="710" width="395" height="350" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
