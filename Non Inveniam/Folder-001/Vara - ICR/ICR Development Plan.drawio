        </mxCell>
        <mxCell id="H5EQN1q-07Lq3T8gzeKI-2" value="Imported Data" style="ellipse;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="610" y="100" width="120" height="80" as="geometry" />
        </mxCell>
        <mxCell id="H5EQN1q-07Lq3T8gzeKI-3" value="Generated Data" style="ellipse;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="790" y="100" width="120" height="80" as="geometry" />
        </mxCell>
        <mxCell id="H5EQN1q-07Lq3T8gzeKI-4" value="Master Data" style="ellipse;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="425" y="100" width="120" height="80" as="geometry" />
        </mxCell>
        <mxCell id="H5EQN1q-07Lq3T8gzeKI-5" value="User Management" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="425" y="200" width="120" height="30" as="geometry" />
        </mxCell>
        <mxCell id="H5EQN1q-07Lq3T8gzeKI-6" value="Subsidiary Management" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="425" y="230" width="120" height="30" as="geometry" />
        </mxCell>
        <mxCell id="H5EQN1q-07Lq3T8gzeKI-7" value="Permission Data" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="425" y="260" width="120" height="30" as="geometry" />
        </mxCell>
        <mxCell id="H5EQN1q-07Lq3T8gzeKI-8" value="Configuration" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="425" y="290" width="120" height="30" as="geometry" />
        </mxCell>
        <mxCell id="H5EQN1q-07Lq3T8gzeKI-10" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Functionalities with master data&lt;/h1&gt;&lt;p&gt;&lt;/p&gt;&lt;ol&gt;&lt;li&gt;Organization Admin will CRUD Subsidiary Profile&lt;/li&gt;&lt;li&gt;Organization Admin will add / invite users into the platform&lt;/li&gt;&lt;li&gt;Organization Admin will assign Admin role to the users of a subsidiary&lt;/li&gt;&lt;li&gt;Subsidiary Admin can add anyone in subsidiary user list&amp;nbsp;who are added by the organization admin&lt;/li&gt;&lt;li&gt;If any user is invited into the platform by subsidiary admin and the invited user is subject to accepted by the organization admin&lt;/li&gt;&lt;li&gt;Create Ledger Accounts&lt;/li&gt;&lt;li&gt;Create InterCompany Ledger Accounts&lt;/li&gt;&lt;/ol&gt;&lt;p&gt;&lt;/p&gt;" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="40" y="340" width="395" height="210" as="geometry" />
        </mxCell>
        <mxCell id="en4j18sToLUnwuQMucQo-1" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Initiate Transaction&lt;/h1&gt;&lt;p&gt;&lt;/p&gt;&lt;ol&gt;&lt;li&gt;The platform will give a form to make an transaction entry&lt;/li&gt;&lt;li&gt;The user will select the transaction type, related party / entity, Ledger Accounts, Select InterCompany Account&lt;/li&gt;&lt;li&gt;There may be fields specific to the transaction type&lt;/li&gt;&lt;li&gt;Once the transaction has been prepared, it will go through the approval process (maker, checker and approver)&lt;/li&gt;&lt;/ol&gt;&lt;p&gt;&lt;/p&gt;" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="600" y="340" width="395" height="150" as="geometry" />
        </mxCell>
        <mxCell id="w5XgM56UgNR5U5_wFfUM-1" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Generated Data&lt;/h1&gt;&lt;div&gt;&lt;ol&gt;&lt;li&gt;&lt;br&gt;&lt;/li&gt;&lt;/ol&gt;&lt;/div&gt;&lt;p&gt;&lt;/p&gt;" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="990" y="100" width="395" height="150" as="geometry" />
        </mxCell>
        <mxCell id="w5XgM56UgNR5U5_wFfUM-2" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Import Transaction&lt;/h1&gt;&lt;div&gt;Initiating a direct transaction through the platform is completely managed by the platform. But, there can be data that need to be import from other platform which may be not following the structure that is not supported by the platform.&amp;nbsp;&lt;/div&gt;&lt;div&gt;This feature can be discussed, but it needs to implemented to provide varsatile option to integrate the platform with other platforms.&lt;/div&gt;&lt;p&gt;&lt;/p&gt;" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="600" y="500" width="395" height="150" as="geometry" />
        </mxCell>
        <mxCell id="w5XgM56UgNR5U5_wFfUM-3" value="Raw Txn Data" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="610" y="200" width="120" height="30" as="geometry" />
        </mxCell>
        <mxCell id="w5XgM56UgNR5U5_wFfUM-4" value="Account Balance" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="610" y="230" width="120" height="30" as="geometry" />
        </mxCell>
        <mxCell id="w5XgM56UgNR5U5_wFfUM-5" value="Txn Metadata" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="610" y="260" width="120" height="30" as="geometry" />
        </mxCell>
        <mxCell id="w5XgM56UgNR5U5_wFfUM-6" value="Txn Matching" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="790" y="200" width="120" height="30" as="geometry" />
        </mxCell>
        <mxCell id="w5XgM56UgNR5U5_wFfUM-7" value="Txn Matching Result" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="790" y="230" width="120" height="30" as="geometry" />
        </mxCell>
        <mxCell id="w5XgM56UgNR5U5_wFfUM-8" value="Reconciliation Result" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="790" y="260" width="120" height="30" as="geometry" />
        </mxCell>
        <mxCell id="w5XgM56UgNR5U5_wFfUM-9" value="Deprecancy Resolution" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="790" y="290" width="120" height="30" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="LZA9kQggtuHrsas3GG2P" name="Transaction Matching Module">
    <mxGraphModel grid="1" page="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="1OOmJYpVmW4WWuZK2iIX-1" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Transaction Matching Algorithm&lt;/h1&gt;&lt;p&gt;Transaction matching is based on rules. The rules have 3 components&lt;/p&gt;&lt;p&gt;1. Filtering Logic&lt;/p&gt;&lt;p&gt;2. Grouping Logic&lt;/p&gt;&lt;p&gt;3. Calculation&lt;/p&gt;&lt;p&gt;We calculate difference by performing necessary calculations on the filtered transactions using the following formula,&lt;/p&gt;&lt;p style=&quot;text-align: center;&quot;&gt;diff = (LHS - RHS)&lt;/p&gt;&lt;p style=&quot;&quot;&gt;If the diff is within the tolerance level, then the group is considered as Matched, otherwise, the group is considered as partially matched. If there is no corresponding items in LHS or RHS, then the transactions are considered as not matched.&lt;/p&gt;" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="50" y="160" width="440" height="290" as="geometry" />
        </mxCell>
        <mxCell id="1OOmJYpVmW4WWuZK2iIX-3" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Transaction Matching Algorithm&lt;/h1&gt;&lt;p&gt;Transaction matching is based on rules. The rules have 3 components&lt;/p&gt;&lt;p&gt;1. Filtering Logic&lt;/p&gt;&lt;p&gt;2. Grouping Logic&lt;/p&gt;&lt;p&gt;3. Calculation&lt;/p&gt;&lt;p&gt;We calculate difference by performing necessary calculations on the filtered transactions using the following formula,&lt;/p&gt;&lt;p style=&quot;text-align: center;&quot;&gt;diff = (LHS - RHS)&lt;/p&gt;&lt;p style=&quot;&quot;&gt;If the diff is within the tolerance level, then the group is considered as Matched, otherwise, the group is considered as partially matched. If there is no corresponding items in LHS or RHS, then the transactions are considered as not matched.&lt;/p&gt;" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="510" y="160" width="440" height="290" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
