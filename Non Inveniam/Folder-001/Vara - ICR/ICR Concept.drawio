        <mxCell id="056RRzdfOuOOhiHgeSEj-2" value="Child 2" style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;html=1;outlineConnect=0;" vertex="1" parent="1">
          <mxGeometry x="610" y="260" width="30" height="60" as="geometry" />
        </mxCell>
        <mxCell id="056RRzdfOuOOhiHgeSEj-5" value="" style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];outlineConnect=0;fontColor=#232F3E;fillColor=#ED7100;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.quantum_ledger_database;" vertex="1" parent="1">
          <mxGeometry x="430" y="400" width="78" height="78" as="geometry" />
        </mxCell>
        <mxCell id="056RRzdfOuOOhiHgeSEj-6" value="" style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];outlineConnect=0;fontColor=#232F3E;fillColor=#C925D1;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.quantum_ledger_database;" vertex="1" parent="1">
          <mxGeometry x="600" y="400" width="78" height="78" as="geometry" />
        </mxCell>
        <mxCell id="056RRzdfOuOOhiHgeSEj-8" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Key Considerations&lt;/h1&gt;&lt;p&gt;1. Both parties have their own ledger to main the transaction infromation&lt;/p&gt;&lt;p&gt;2. There are not necessarily both ledger have same collumn and rows. Because, both parties have their way of managing transactions.&lt;/p&gt;&lt;p&gt;3. But, at the end of the year, we have to tally both the ledgers to transparent accounting.&lt;/p&gt;" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="20" y="250" width="300" height="190" as="geometry" />
        </mxCell>
        <mxCell id="056RRzdfOuOOhiHgeSEj-10" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Intercompany Reconciliation&lt;/h1&gt;&lt;p&gt;1. Related Parites: Parent &amp;lt;-&amp;gt; child, child &amp;lt;-&amp;gt;child&lt;/p&gt;&lt;p&gt;2. For transparent accounting and tax saving, the parent company need to declare the inter-company transactions to set-off profit and loss&lt;/p&gt;&lt;p&gt;3. Identification and reconciliation is very much required for netting and settling.&lt;/p&gt;" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="20" y="490" width="340" height="170" as="geometry" />
        </mxCell>
        <mxCell id="056RRzdfOuOOhiHgeSEj-11" value="Parent" style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;html=1;outlineConnect=0;" vertex="1" parent="1">
          <mxGeometry x="530" y="120" width="30" height="60" as="geometry" />
        </mxCell>
        <mxCell id="056RRzdfOuOOhiHgeSEj-12" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Transaction Reconciliation&lt;/h1&gt;&lt;p&gt;1. Identification of Related Party transactions&lt;/p&gt;&lt;p&gt;2. Group based on common informations&amp;nbsp;&lt;/p&gt;&lt;p&gt;3. Calculate the net value of the transaction&amp;nbsp;&lt;/p&gt;&lt;p&gt;4. If the net transaction amount is zero, then we can say the transactions are settled&lt;/p&gt;" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="770" y="255" width="320" height="175" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
