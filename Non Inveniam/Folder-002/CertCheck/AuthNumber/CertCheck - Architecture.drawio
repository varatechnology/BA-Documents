        <mxCell id="cumKQtxTqq7uW4ipGRIu-18" value="REST Server&lt;br&gt;(Gateway to HLF Network)" style="rounded=0;whiteSpace=wrap;html=1;" parent="1" vertex="1">
          <mxGeometry x="2038" y="362" width="213" height="60" as="geometry" />
        </mxCell>
        <mxCell id="cumKQtxTqq7uW4ipGRIu-20" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0.992;entryY=0.607;entryDx=0;entryDy=0;entryPerimeter=0;startArrow=classic;startFill=1;" parent="1" source="cumKQtxTqq7uW4ipGRIu-10" target="cumKQtxTqq7uW4ipGRIu-5" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="cumKQtxTqq7uW4ipGRIu-22" value="gPRC&lt;br&gt;TLS" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];" parent="cumKQtxTqq7uW4ipGRIu-20" connectable="0" vertex="1">
          <mxGeometry x="0.2047" y="1" relative="1" as="geometry">
            <mxPoint x="19" as="offset" />
          </mxGeometry>
        </mxCell>
        <mxCell id="cumKQtxTqq7uW4ipGRIu-25" value="&lt;h1&gt;Hyperledger Network Components&lt;/h1&gt;&lt;p&gt;1. Orderer Organization: This organization is mandatory for hyperledger network.&lt;/p&gt;&lt;p&gt;2. Orderer Node: Orderer nodes are part of Orderer organization. These nodes are not used for chaincode execution, but these nodes are used to order the transaction propotions into the block.&lt;/p&gt;&lt;p&gt;3. Member Organization: Apart from orderer organization, various organization can be part of the hyperledger network. Each organization is treated as member in the network.&lt;/p&gt;&lt;p&gt;4. Endorser Node: Each organization hosts its peer nodes to the network. The peer nodes with chaincode installed is called the endorser nodes.&lt;/p&gt;&lt;p&gt;5. REST Server: This server will subscribe the network as client and act as Gateway to interact with the hyperledger with a public facing end point.&lt;/p&gt;" style="text;html=1;strokeColor=none;fillColor=none;spacing=5;spacingTop=-20;whiteSpace=wrap;overflow=hidden;rounded=0;" parent="1" vertex="1">
          <mxGeometry x="1773" y="462" width="529" height="241" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
